@model IEnumerable<QuantEdge.Web.Models.HolidayViewModel>
@{
    ViewData["Title"] = "Holiday Manager";
    ViewData["PageTitle"] = "Indian Stock Market Holiday Manager";
}

<!-- Alert Banners -->
@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success" id="successAlert" role="alert">
        <div class="alert-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </div>
        <span class="alert-text">@ViewBag.SuccessMessage</span>
        <button class="alert-close" onclick="this.parentElement.style.display='none'" aria-label="Close">×</button>
    </div>
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger" id="errorAlert" role="alert">
        <div class="alert-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
        </div>
        <span class="alert-text">@ViewBag.ErrorMessage</span>
        <button class="alert-close" onclick="this.parentElement.style.display='none'" aria-label="Close">×</button>
    </div>
}

<div class="holiday-dashboard-grid">

    <!-- Holiday List Card -->
    <div class="card card-primary">
        <div class="card-header">
            <div class="card-header-icon" style="background: linear-gradient(135deg, rgba(79, 156, 249, 0.15), rgba(124, 92, 252, 0.1)); color: var(--theme-accent); border: 1px solid var(--theme-border);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
            </div>
            <div>
                <h2 class="card-title">Configured Market Holidays</h2>
                <p class="card-subtitle">WebSocket connection and data processing are paused on these dates</p>
            </div>
        </div>

        <div class="card-body">
            @if (Model == null || !Model.Any())
            {
                <div class="no-holidays-msg">
                    No holidays configured yet. The background service will run strictly from Monday to Friday based on time.
                </div>
            }
            else
            {
                <div class="holiday-list">
                    <div class="holiday-header-row">
                        <div>Date (IST)</div>
                        <div>Description</div>
                        <div style="text-align: right;">Action</div>
                    </div>
                    @foreach (var holiday in Model)
                    {
                        <div class="holiday-row">
                            <div class="holiday-date">@holiday.HolidayDate.ToString("dd MMM yyyy")</div>
                            <div class="holiday-desc">@holiday.Description</div>
                            <div class="holiday-action">
                                <form asp-controller="Holiday" asp-action="Delete" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@holiday.Id" />
                                    <button type="submit" class="btn-delete" onclick="return confirm('Are you sure you want to delete this holiday: &quot;@holiday.Description&quot;?')">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Add Holiday Form Card -->
    <div class="card card-info">
        <div class="card-header">
            <div class="card-header-icon" style="background: linear-gradient(135deg, rgba(52, 211, 153, 0.15), rgba(5, 150, 105, 0.1)); color: var(--theme-accent); border: 1px solid var(--theme-border);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="12" y1="18" x2="12" y2="12"></line>
                    <line x1="9" y1="15" x2="15" y2="15"></line>
                </svg>
            </div>
            <div>
                <h2 class="card-title">Add Market Holiday</h2>
                <p class="card-subtitle">Register a new trading holiday</p>
            </div>
        </div>

        <div class="card-body">
            <form asp-controller="Holiday" asp-action="Create" method="post">
                <div class="form-group">
                    <label class="form-label" for="holidayDate">Holiday Date</label>
                    <input type="date" class="form-input" id="holidayDate" name="holidayDate" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="description">Description</label>
                    <input type="text" class="form-input" id="description" name="description" placeholder="e.g. Diwali, Independence Day" required autocomplete="off" />
                </div>

                <div style="margin-top: 30px;">
                    <button type="submit" class="btn-primary-action" style="width: 100%; border: none; justify-content: center; cursor: pointer;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Save Holiday
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>

<style>
    .holiday-dashboard-grid {
        display: grid;
        grid-template-columns: 1.3fr 1fr;
        gap: 24px;
        align-items: start;
    }
    
    @@media (max-width: 992px) {
        .holiday-dashboard-grid {
            grid-template-columns: 1fr;
        }
    }

    .holiday-list {
        display: flex;
        flex-direction: column;
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid var(--border-subtle);
        overflow: hidden;
    }

    .holiday-header-row {
        display: grid;
        grid-template-columns: 130px 1fr 100px;
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.03);
        border-bottom: 1px solid var(--border-subtle);
        font-weight: 600;
        font-size: 13px;
        color: var(--text-primary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .holiday-row {
        display: grid;
        grid-template-columns: 130px 1fr 100px;
        align-items: center;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border-subtle);
        transition: background 0.2s ease;
    }

    .holiday-row:last-child {
        border-bottom: none;
    }

    .holiday-row:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .holiday-date {
        font-weight: 600;
        color: var(--theme-accent);
        font-family: monospace;
        font-size: 14px;
    }

    .holiday-desc {
        color: var(--text-primary);
        font-size: 14px;
        padding-right: 15px;
        word-break: break-word;
    }

    .holiday-action {
        text-align: right;
    }

    .btn-delete {
        background: rgba(248, 113, 113, 0.08);
        color: #f87171;
        border: 1px solid rgba(248, 113, 113, 0.15);
        padding: 6px 12px;
        border-radius: var(--radius-sm, 4px);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-delete:hover {
        background: rgba(248, 113, 113, 0.2);
        border-color: rgba(248, 113, 113, 0.35);
        box-shadow: 0 4px 12px rgba(248, 113, 113, 0.15);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        border-radius: var(--radius-md);
        background-color: #1e2640 !important;
        border: 1px solid var(--border-subtle) !important;
        color: white;
        font-size: 14px;
        transition: all 0.2s ease;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--theme-accent) !important;
        box-shadow: 0 0 0 3px var(--theme-glow);
    }

    .no-holidays-msg {
        padding: 30px;
        text-align: center;
        color: var(--text-muted);
        font-size: 14px;
        border: 1px dashed var(--border-subtle);
        border-radius: var(--radius-md);
        background: rgba(255,255,255,0.005);
    }
</style>
