@{
    ViewData["Title"] = "Data Coverage Manager";
    ViewData["PageTitle"] = "Data Coverage Manager";
}

<link rel="stylesheet" href="~/css/datacoverage.css" asp-append-version="true" />

<div class="coverage-container" data-api-base-url="@ViewBag.ApiBaseUrl">
    <!-- Top KPI Summary Cards -->
    <div class="kpi-grid">
        <div class="kpi-card dc-total">
            <div class="kpi-header">
                <span class="kpi-label">Total Stocks</span>
                <div class="kpi-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-8 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"></path></svg></div>
            </div>
            <div id="kpiTotalStocks" class="kpi-value">...</div>
            <div class="kpi-subtext">All instruments</div>
        </div>
        <div class="kpi-card dc-active">
            <div class="kpi-header">
                <span class="kpi-label">Active</span>
                <div class="kpi-icon" style="color:var(--accent-green)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            </div>
            <div id="kpiActiveCount" class="kpi-value active-color">...</div>
            <div class="kpi-subtext">Being tracked</div>
        </div>
        <div class="kpi-card dc-inactive">
            <div class="kpi-header">
                <span class="kpi-label">Inactive</span>
                <div class="kpi-icon" style="color:var(--accent-red)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg></div>
            </div>
            <div id="kpiInactiveCount" class="kpi-value inactive-color">...</div>
            <div class="kpi-subtext">Not monitored</div>
        </div>
        <div class="kpi-card dc-missing">
            <div class="kpi-header">
                <span class="kpi-label">History Missing</span>
                <div class="kpi-icon" style="color:var(--accent-amber)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg></div>
            </div>
            <div id="kpiMissingCount" class="kpi-value warning-color">...</div>
            <div class="kpi-subtext">Need backfill</div>
        </div>
    </div>

    <!-- Filter & Control Bar -->
    <div class="filter-bar">
        <div class="filter-group">
            <select id="statusFilter" class="filter-select">
                <option value="all">All status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>

            <select id="historyFilter" class="filter-select">
                <option value="all">All history</option>
                <option value="missing">History missing</option>
                <option value="1d_missing">1D Missing</option>
                <option value="60m_missing">60m Missing</option>
                <option value="has_1d">Has 1D History</option>
                <option value="has_60m">Has 60m History</option>
            </select>

            <div class="search-input-wrapper">
                <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" id="searchInput" class="search-input" placeholder="Search symbol or name..." />
            </div>
        </div>

        <div class="filter-group">
            <button type="button" id="btnRefreshCoverage" class="btn-refresh-coverage" title="Refresh stock list">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="23 4 23 10 17 10"></polyline>
                    <polyline points="1 20 1 14 7 14"></polyline>
                    <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                </svg>
                Refresh
            </button>
            <span style="font-size:12px;color:var(--text-muted);font-weight:600;margin-left:8px;">Per page:</span>
            <select id="pageSizeSelect" class="filter-select" style="min-width:80px;">
                <option value="10">10</option>
                <option value="25" selected>25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>
    </div>

    <!-- Bulk Action Toolbar -->
    <div id="bulkActionsBar" class="bulk-actions-bar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
        <span><span id="selectedCount">0</span> items selected</span>
        <button type="button" id="btnBulkDelete" class="btn-delete-stock btn-sm">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            Delete Selected
        </button>
    </div>

    <!-- Data Table Card -->
    <div class="table-card">
        <div style="overflow-x: auto;">
            <table class="coverage-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"><input type="checkbox" id="selectAllCheckbox" /></th>
                        <th style="min-width: 140px;">Symbol & Exchange</th>
                        <th style="min-width: 200px;">Company Name</th>
                        <th style="min-width: 240px;">Timeframe History Flags</th>
                        <th style="min-width: 150px;">Last Candle Sync</th>
                        <th style="min-width: 110px;">Status</th>
                    </tr>
                </thead>
                <tbody id="coverageTableBody">
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 40px; color: #94a3b8;">
                            Loading stock data coverage...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination Controls Bar -->
        <div class="pagination-wrapper">
            <div id="paginationInfo" class="pagination-info">
                Showing 0 to 0 of 0 stocks
            </div>
            <div id="paginationControls" class="pagination-controls">
                <!-- Page buttons rendered dynamically by datacoverage.js -->
            </div>
        </div>
    </div>

    <!-- Stock Details & Edit Card Panel -->
    <div id="detailCard" class="detail-card" style="display: none;">
        <div class="detail-card-header">
            <div class="detail-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                </svg>
                <span id="detailSymbol">...</span> Stock Specification
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <button type="button" id="btnCloseDetailCard" class="btn-close-detail" title="Close Specification Panel">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
        </div>

        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-item-label">Company Name</span>
                <span id="detailName" class="detail-item-value">...</span>
            </div>
            <div class="detail-item">
                <span class="detail-item-label">Exchange</span>
                <span id="detailExchange" class="detail-item-value">NSE</span>
            </div>
            <div class="detail-item">
                <span class="detail-item-label">Status</span>
                <span id="detailStatus" class="detail-item-value">Active</span>
            </div>
            <div class="detail-item">
                <span class="detail-item-label">Last Candle Date</span>
                <span id="detailLastCandleDate" class="detail-item-value">No data</span>
            </div>
            <div class="detail-item">
                <span class="detail-item-label">Instrument Token</span>
                <span id="detailInstrumentToken" class="detail-item-value monospace">...</span>
            </div>
        </div>

        <!-- Flags Edit / Save Section -->
        <div class="flags-edit-section">
            <div class="flags-section-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Manage Active Status & Timeframe History Flags
            </div>
            <form id="editFlagsForm">
                <input type="hidden" id="editStockId" value="" />
                
                <div class="flags-grid">
                    <div class="flag-toggle-card">
                        <div>
                            <span class="flag-label">Active Status</span>
                            <span class="flag-sublabel">Track symbol in data service</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="chkIsActive" />
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="flag-toggle-card">
                        <div>
                            <span class="flag-label">1 Min History</span>
                            <span class="flag-sublabel">1m candle data stored</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="chkHistory1m" />
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="flag-toggle-card">
                        <div>
                            <span class="flag-label">5 Min History</span>
                            <span class="flag-sublabel">5m candle data stored</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="chkHistory5m" />
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="flag-toggle-card">
                        <div>
                            <span class="flag-label">15 Min History</span>
                            <span class="flag-sublabel">15m candle data stored</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="chkHistory15m" />
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="flag-toggle-card">
                        <div>
                            <span class="flag-label">60 Min History</span>
                            <span class="flag-sublabel">60m candle data stored</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="chkHistory60m" />
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="flag-toggle-card">
                        <div>
                            <span class="flag-label">Daily History</span>
                            <span class="flag-sublabel">1d candle data stored</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="chkHistory1d" />
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>

                <div class="detail-actions-row">
                    <button type="button" id="btnDeleteStock" class="btn-delete-stock">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                        Delete Stock
                    </button>
                    <button type="button" id="btnSaveCoverageFlags" class="btn-save-coverage">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                            <polyline points="17 21 17 13 7 13 7 21"></polyline>
                            <polyline points="7 3 7 8 15 8"></polyline>
                        </svg>
                        Save / Update Flags
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/datacoverage.js" asp-append-version="true"></script>
}
