@model QuantEdge.Web.Models.TokenViewModel
@{
    ViewData["Title"] = "Token Manager";
    ViewData["PageTitle"] = "Token Manager";
}

<!-- Status Banner -->
@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-@Model.StatusType" id="statusAlert" role="alert">
        <div class="alert-icon">
            @if (Model.StatusType == "success")
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            }
            else
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            }
        </div>
        <span class="alert-text">@Model.StatusMessage</span>
        <button class="alert-close" onclick="this.parentElement.style.display='none'" aria-label="Close">×</button>
    </div>
}

<!-- ============================================================
     ACTIVE SESSION — Shown when token exists
     ============================================================ -->
@if (Model.HasActiveToken)
{
    <!-- Status KPI mini-cards -->
    <div class="kpi-row" style="grid-template-columns: repeat(3, 1fr); margin-bottom: 24px;">
        <div class="kpi-card" style="--kpi-color: var(--accent-green);">
            <div class="kpi-header">
                <span class="kpi-label">Token Status</span>
                <div class="kpi-icon" style="color:var(--accent-green);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
            </div>
            <div style="margin-top:4px;">
                <span class="badge badge-success" style="font-size:13px;height:28px;padding:0 14px;">
                    <span class="badge-dot"></span> Active
                </span>
            </div>
            <div class="kpi-subtext">Valid for today</div>
        </div>
        <div class="kpi-card" style="--kpi-color: var(--theme-accent);">
            <div class="kpi-header">
                <span class="kpi-label">Generated At</span>
                <div class="kpi-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
            </div>
            <div style="font-size:15px;font-weight:700;color:var(--text-primary);margin-top:4px;font-variant-numeric:tabular-nums;">
                @(Model.CreatedAtIst ?? "—")
            </div>
            <div class="kpi-subtext">IST</div>
        </div>
        <div class="kpi-card" style="--kpi-color: var(--accent-amber);">
            <div class="kpi-header">
                <span class="kpi-label">Expires At</span>
                <div class="kpi-icon" style="color:var(--accent-amber);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                </div>
            </div>
            <div style="font-size:15px;font-weight:700;color:var(--accent-amber);margin-top:4px;">
                6:00 AM IST
            </div>
            <div class="kpi-subtext">Next day reset</div>
        </div>
    </div>

    <!-- Active Session Card -->
    <div class="card card-success" style="margin-bottom: 20px;">
        <div class="card-header">
            <div class="card-header-inner">
                <div class="card-header-icon icon-check">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <div>
                    <h2 class="card-title">Active Session Information</h2>
                    <p class="card-subtitle">Zerodha Access Token saved and ready</p>
                </div>
            </div>
            <div class="card-header-actions">
                <span class="badge badge-success" style="font-size:12px;height:26px;padding:0 12px;">
                    <span class="badge-dot"></span> Active for Today
                </span>
            </div>
        </div>
        <div class="card-body">
            <div class="session-info-grid">
                @if (!string.IsNullOrEmpty(Model.UserName))
                {
                    <div class="info-row">
                        <span class="info-label">User Name</span>
                        <span class="info-value">@Model.UserName</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div class="info-row">
                        <span class="info-label">Email</span>
                        <span class="info-value">@Model.Email</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.ApiKey))
                {
                    <div class="info-row">
                        <span class="info-label">API Key</span>
                        <span class="info-value monospace">@Model.ApiKey</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.AccessTokenMasked))
                {
                    <div class="info-row">
                        <span class="info-label">Access Token</span>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <span class="info-value monospace token-masked" id="tokenDisplay">@Model.AccessTokenMasked</span>
                            <button type="button" class="btn-icon-only btn-xs" onclick="copyToken()" title="Copy token" style="width:28px;height:28px;">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div style="margin-top:20px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.08);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
                <span style="font-size:12px;color:var(--text-muted);display:flex;align-items:center;gap:6px;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                    Token resets automatically at 6:00 AM IST
                </span>
                <a asp-controller="Token" asp-action="CreateToken"
                   class="btn-secondary btn-sm"
                   onclick="return confirm('Re-create Zerodha Access Token?')">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path><path d="M16 3h5v5"></path></svg>
                    Re-create Token
                </a>
            </div>
        </div>
    </div>
}

<!-- ============================================================
     CREATE TOKEN — Shown when no token exists
     ============================================================ -->
@if (!Model.HasActiveToken)
{
    <div class="card card-primary" style="margin-bottom: 20px;">
        <div class="card-header">
            <div class="card-header-inner">
                <div class="card-header-icon icon-key">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
                </div>
                <div>
                    <h2 class="card-title">Create Access Token</h2>
                    <p class="card-subtitle">Authenticate with Zerodha via OAuth 2.0</p>
                </div>
            </div>
        </div>

        <div class="card-body">
            <!-- OAuth Flow Steps -->
            <div class="flow-steps">
                <div class="flow-step">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <div class="step-title">Initiate OAuth</div>
                        <div class="step-desc">Click button → API fetches login URL</div>
                    </div>
                </div>
                <div class="flow-arrow">→</div>
                <div class="flow-step">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <div class="step-title">Zerodha Login</div>
                        <div class="step-desc">Enter credentials + 2FA TOTP</div>
                    </div>
                </div>
                <div class="flow-arrow">→</div>
                <div class="flow-step">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <div class="step-title">Callback & Save</div>
                        <div class="step-desc">Token exchanged & saved to DB</div>
                    </div>
                </div>
            </div>

            <div class="btn-wrapper">
                <a asp-controller="Token" asp-action="CreateToken"
                   class="btn-create-token"
                   id="createTokenBtn"
                   onclick="handleCreateTokenClick(event, this)">
                    <div class="btn-shimmer"></div>
                    <span class="btn-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
                    </span>
                    <span class="btn-text">Create Token</span>
                    <span class="btn-arrow">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </span>
                </a>
                <div class="btn-hint">You'll be redirected to <strong>kite.zerodha.com</strong> to complete login</div>
            </div>
        </div>
    </div>
}

<!-- ============================================================
     TOKEN LIFECYCLE INFO — Timeline
     ============================================================ -->
<div class="card">
    <div class="card-header">
        <div class="card-header-inner">
            <div class="card-header-icon icon-info">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </div>
            <div>
                <h2 class="card-title">Token Lifecycle</h2>
                <p class="card-subtitle">Daily authentication flow for Zerodha sessions</p>
            </div>
        </div>
    </div>
    <div class="card-body" style="display:grid;grid-template-columns:1fr 1fr;gap:32px;">
        <!-- Timeline -->
        <div>
            <div style="font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:16px;">Today's Flow</div>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-dot success"></div>
                    <div class="timeline-content">
                        <div class="timeline-label">Manual Login</div>
                        <div class="timeline-desc">User opens Token Manager & initiates OAuth</div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-dot success"></div>
                    <div class="timeline-content">
                        <div class="timeline-label">Token Generated</div>
                        <div class="timeline-desc">Zerodha issues access token after 2FA</div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-dot success"></div>
                    <div class="timeline-content">
                        <div class="timeline-label">Saved to Database</div>
                        <div class="timeline-desc">Token persisted to PostgreSQL via callback</div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-dot @(Model.HasActiveToken ? "active" : "")"></div>
                    <div class="timeline-content">
                        <div class="timeline-label">Worker Picks Token</div>
                        <div class="timeline-desc">Background service auto-loads token for trading</div>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-dot warning"></div>
                    <div class="timeline-content">
                        <div class="timeline-label">Token Expires</div>
                        <div class="timeline-desc">Daily reset at 6:00 AM IST — repeat tomorrow</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Info notes -->
        <div>
            <div style="font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:16px;">Important Notes</div>
            <ul class="info-list">
                <li>
                    <div class="info-bullet info-bullet-amber"></div>
                    <span>Zerodha tokens expire <strong>daily at 6:00 AM IST</strong>. Regenerate every trading day.</span>
                </li>
                <li>
                    <div class="info-bullet info-bullet-blue"></div>
                    <span>Token is saved to <strong>PostgreSQL</strong> and auto-loaded by the Worker service.</span>
                </li>
                <li>
                    <div class="info-bullet info-bullet-green"></div>
                    <span>Callback URL must be registered in Zerodha Developer Console:<br>
                        <code class="inline-code">https://localhost:44370/api/zerodha/callback</code>
                    </span>
                </li>
                <li>
                    <div class="info-bullet info-bullet-purple"></div>
                    <span>Use <strong>Headless Login</strong> via <code class="inline-code">POST /api/zerodha/headless-login</code> to automate TOTP.</span>
                </li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/token-manager.js" asp-append-version="true"></script>
    <script>
        function copyToken() {
            const el = document.getElementById('tokenDisplay');
            if (!el) return;
            navigator.clipboard.writeText(el.textContent.trim()).then(() => {
                showToast('Token copied to clipboard', 'success');
            }).catch(() => {
                showToast('Could not copy token', 'error');
            });
        }
    </script>
}
