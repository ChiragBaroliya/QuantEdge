@model QuantEdge.Web.Models.TokenViewModel
@{
    ViewData["Title"] = Model.IsSuccess ? "Token Created" : "Token Failed";
    ViewData["PageTitle"] = Model.IsSuccess ? "Authentication Successful" : "Authentication Failed";
}

<div class="callback-page">

    @if (Model.IsSuccess)
    {
        <!-- SUCCESS STATE -->
        <div class="callback-hero success-hero">
            <div class="hero-icon-wrapper">
                <div class="hero-ring ring-1"></div>
                <div class="hero-ring ring-2"></div>
                <div class="hero-icon-bg hero-icon-bg-success">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                </div>
            </div>
            <h2 class="hero-title">Token Created Successfully</h2>
            <p class="hero-subtitle">
                Your Zerodha session has been authenticated. The access token is now saved in the database
                and the Worker service will automatically use it for live market data streaming.
            </p>
        </div>

        <!-- RESULT CARDS GRID -->
        <div class="result-grid">

            <!-- Session Info Card -->
            <div class="result-card result-card-main">
                <div class="result-card-header">
                    <div class="result-card-icon icon-user">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                    <span class="result-card-title">Session Information</span>
                    <span class="status-chip status-chip-success">
                        <span class="chip-dot"></span>
                        Active
                    </span>
                </div>

                <div class="info-table">
                    @if (!string.IsNullOrEmpty(Model.UserName))
                    {
                        <div class="info-table-row">
                            <span class="info-key">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                User Name
                            </span>
                            <span class="info-val info-val-highlight">@Model.UserName</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <div class="info-table-row">
                            <span class="info-key">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                                Email
                            </span>
                            <span class="info-val">@Model.Email</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ApiKey))
                    {
                        <div class="info-table-row">
                            <span class="info-key">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                                API Key
                            </span>
                            <span class="info-val info-val-mono">@Model.ApiKey</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.AccessTokenMasked))
                    {
                        <div class="info-table-row">
                            <span class="info-key">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                Access Token
                            </span>
                            <span class="info-val info-val-mono info-val-token">@Model.AccessTokenMasked</span>
                        </div>
                    }
                    <div class="info-table-row">
                        <span class="info-key">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            Created At
                        </span>
                        <span class="info-val">@DateTime.Now.ToString("dd MMM yyyy, hh:mm:ss tt")</span>
                    </div>
                    <div class="info-table-row">
                        <span class="info-key">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
                            Stored In
                        </span>
                        <span class="info-val">PostgreSQL · zerodha_sessions</span>
                    </div>
                </div>
            </div>

            <!-- What's Next Card -->
            <div class="result-card result-card-next">
                <div class="result-card-header">
                    <div class="result-card-icon icon-rocket">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 19.1 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23.45 13.45a.84.84 0 0 1-.8.94z"></path>
                        </svg>
                    </div>
                    <span class="result-card-title">What Happens Next</span>
                </div>

                <ul class="next-steps">
                    <li class="next-step">
                        <div class="step-icon step-icon-green">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        </div>
                        <div>
                            <div class="step-label">Token saved to database</div>
                            <div class="step-hint">Persisted in <code>zerodha_sessions</code> table via stored procedure</div>
                        </div>
                    </li>
                    <li class="next-step">
                        <div class="step-icon step-icon-blue">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                        </div>
                        <div>
                            <div class="step-label">Worker service picks it up automatically</div>
                            <div class="step-hint">ZerodhaWebSocketMarketDataService resolves token from DB on connect</div>
                        </div>
                    </li>
                    <li class="next-step">
                        <div class="step-icon step-icon-amber">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        </div>
                        <div>
                            <div class="step-label">Token expires at 6:00 AM IST tomorrow</div>
                            <div class="step-hint">Click "Create Token" again each trading day</div>
                        </div>
                    </li>
                </ul>
            </div>

        </div>

        <!-- Actions -->
        <div class="callback-actions">
            <a asp-controller="Token" asp-action="Index" class="btn-primary-action">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to Dashboard
            </a>
            <a asp-controller="Token" asp-action="CreateToken" class="btn-secondary-action">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
                </svg>
                Create New Token
            </a>
        </div>
    }
    else
    {
        <!-- FAILURE STATE -->
        <div class="callback-hero error-hero">
            <div class="hero-icon-wrapper">
                <div class="hero-icon-bg hero-icon-bg-error">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                    </svg>
                </div>
            </div>
            <h2 class="hero-title">Token Creation Failed</h2>
            <p class="hero-subtitle">
                @(Model.StatusMessage ?? "An error occurred during the Zerodha authentication flow. Please try again.")
            </p>
        </div>

        <div class="error-tips">
            <div class="error-tips-title">Common Causes</div>
            <ul class="error-tip-list">
                <li>The <strong>request_token</strong> already expired (tokens are single-use and expire in a few minutes)</li>
                <li>The Zerodha <strong>ApiSecret</strong> is incorrect in <code>appsettings.json</code></li>
                <li>The <strong>Redirect URL</strong> in Zerodha Developer Console does not match <code>https://localhost:44370/api/zerodha/callback</code></li>
            </ul>
        </div>

        <div class="callback-actions">
            <a asp-controller="Token" asp-action="CreateToken" class="btn-primary-action">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
                </svg>
                Try Again
            </a>
            <a asp-controller="Token" asp-action="Index" class="btn-secondary-action">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to Dashboard
            </a>
        </div>
    }

</div>
