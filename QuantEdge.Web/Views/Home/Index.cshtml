@{
    ViewData["Title"] = "Real-time Signals";
    ViewData["PageTitle"] = "Market Signal Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="dashboard-container">
    <!-- Filters & Selection Row -->
    <div class="control-panel card">
        <div class="control-left">
            <div class="input-group">
                <label for="stockSelector">
                    Asset Symbol
                    <span class="info-tooltip-trigger" data-tooltip="The specific company/stock you are analyzing (e.g. Reliance, INFY).">
                        <svg class="info-icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </label>
                <select id="stockSelector" class="custom-select">
                    <option value="" disabled selected>Select stock...</option>
                </select>
            </div>
            
            <div class="timeframe-group">
                <label>
                    Timeframe
                    <span class="info-tooltip-trigger" data-tooltip="The time duration represented by each bar on the chart (1 Minute, 5 Minutes, or 15 Minutes). Shorter times show quick changes; longer times show broader trends.">
                        <svg class="info-icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </label>
                <div class="tabs">
                    <button class="tab-btn active" data-timeframe="1m">1 MIN</button>
                    <button class="tab-btn" data-timeframe="5m">5 MIN</button>
                    <button class="tab-btn" data-timeframe="15m">15 MIN</button>
                </div>
            </div>
        </div>

        <div class="control-right" style="display: flex; align-items: center; gap: 12px;">
            <button id="btnOpenReference" class="btn-trigger" style="display: flex; align-items: center; gap: 8px;" title="View Strategy Rules, Scoring Weights, and Backend Mathematical Formulas.">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                </svg>
                Rules & Formulas
            </button>
            <div id="connectionStatus" class="connection-badge offline" data-tooltip="Shows if you are connected to the live market data feed. 'Connected' means you are receiving instant, real-time price updates.">
                <span class="status-dot"></span>
                <span class="status-text">Disconnected</span>
            </div>
        </div>
    </div>

    <!-- Main Signal Indicator Grid -->
    <div class="signal-grid">
        <!-- Live Signal glow card -->
        <div id="signalCard" class="card signal-card hold">
            <div class="signal-card-header">
                <span class="card-section-title">
                    AI RECOMMENDATION
                    <span class="info-tooltip-trigger" data-tooltip="The trade advice generated by our AI model: BUY (good time to purchase), SELL (good time to sell), or HOLD (wait/do nothing).">
                        <svg class="info-icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </span>
                <div id="signalBadge" class="recommendation-badge hold">HOLD</div>
            </div>
            
            <div class="signal-card-body">
                <div class="score-display">
                    <div class="radial-progress-wrapper" data-tooltip="AI confidence score. Under 40 suggests selling, above 60 suggests buying, and 40 to 60 suggests holding.">
                        <svg class="radial-progress" viewBox="0 0 36 36">
                            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                            <path id="scoreCircle" class="circle" stroke-dasharray="0, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        </svg>
                        <div class="score-value-wrapper">
                            <span id="scoreValue" class="score-num">0</span>
                            <span class="score-label">Score</span>
                        </div>
                    </div>
                </div>

                <div class="signal-metrics">
                    <div class="metric-row">
                        <span class="m-label">
                            Strength
                            <span class="info-tooltip-trigger" data-tooltip="How strong the current advice is (e.g. Weak, Moderate, or Strong).">
                                <svg class="info-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="16" x2="12" y2="12"></line>
                                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                                </svg>
                            </span>
                        </span>
                        <span id="signalStrength" class="m-val">Neutral</span>
                    </div>
                    <div class="metric-row">
                        <span class="m-label">
                            Trigger Price
                            <span class="info-tooltip-trigger" data-tooltip="The exact stock price at the moment this AI recommendation was made.">
                                <svg class="info-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="16" x2="12" y2="12"></line>
                                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                                </svg>
                            </span>
                        </span>
                        <span id="signalPrice" class="m-val monospace">-</span>
                    </div>
                    <div class="metric-row">
                        <span class="m-label">
                            Calculated At
                            <span class="info-tooltip-trigger" data-tooltip="The exact time when this AI recommendation was calculated.">
                                <svg class="info-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="16" x2="12" y2="12"></line>
                                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                                </svg>
                            </span>
                        </span>
                        <span id="signalTime" class="m-val">-</span>
                    </div>
                    <div class="metric-row">
                        <span class="m-label">
                            Confidence
                            <span class="info-tooltip-trigger" data-tooltip="How certain the AI is about its advice (Low, Moderate, High, or Very High) based on supporting indicators.">
                                <svg class="info-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="16" x2="12" y2="12"></line>
                                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                                </svg>
                            </span>
                        </span>
                        <span id="signalConfidence" class="m-val">-</span>
                    </div>
                </div>
            </div>

            <div class="signal-card-footer">
                <div class="reasoning-title">
                    JUSTIFICATION FACTORS
                    <span class="info-tooltip-trigger" data-tooltip="The actual technical reasons and mathematical indicators that caused the AI to make this recommendation.">
                        <svg class="info-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </div>
                <p id="signalReasoning" class="reasoning-text">Please select a stock symbol to load real-time indicators and recommendation triggers.</p>
            </div>
        </div>

        <!-- Metric Details Quick Widgets -->
        <div class="metrics-widget-grid">
            <div class="widget card">
                <span class="w-label">
                    CURRENT PRICE
                    <span class="info-tooltip-trigger" data-tooltip="The latest traded price of the stock and how much it has gone up or down in the current timeframe.">
                        <svg class="info-icon" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </span>
                <div class="w-value-wrapper">
                    <span id="widgetLTP" class="w-value monospace">-</span>
                    <span id="widgetChange" class="w-change neutral">0.00%</span>
                </div>
            </div>

            <div class="widget card">
                <span class="w-label">
                    RSI (14)
                    <span class="info-tooltip-trigger" data-tooltip="Relative Strength Index (RSI). A momentum indicator. Above 60 means the stock might be overbought (price could drop). Below 40 means it might be oversold (price could rise).">
                        <svg class="info-icon" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </span>
                <div class="w-value-wrapper">
                    <span id="widgetRSI" class="w-value monospace">-</span>
                    <span id="widgetRsiStatus" class="w-status neutral">Neutral</span>
                </div>
            </div>

            <div class="widget card">
                <span class="w-label">
                    VWAP DIFFERENCE
                    <span class="info-tooltip-trigger" data-tooltip="Volume Weighted Average Price. Shows the average price weighted by trading volume. If price is above VWAP (positive), the trend is bullish; if below (negative), the trend is bearish.">
                        <svg class="info-icon" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </span>
                <div class="w-value-wrapper">
                    <span id="widgetVWAP" class="w-value monospace">-</span>
                    <span id="widgetVwapStatus" class="w-status neutral">-</span>
                </div>
            </div>

            <div class="widget card">
                <span class="w-label">
                    MACD CROSSOVER
                    <span class="info-tooltip-trigger" data-tooltip="Moving Average Convergence Divergence. A trend momentum indicator. 'Bullish' suggests upward momentum (buy signal); 'Bearish' suggests downward momentum (sell signal).">
                        <svg class="info-icon" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </span>
                <div class="w-value-wrapper">
                    <span id="widgetMACD" class="w-value monospace">-</span>
                    <span id="widgetMacdStatus" class="w-status neutral">No Cross</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Asset Specification Card -->
    <div class="card asset-spec-card">
        <div class="card-header">
            <span class="card-section-title">
                ASSET SPECIFICATION (STOCK MASTER METADATA)
                <span class="info-tooltip-trigger" data-tooltip="Detailed instrument metadata from the stock master database.">
                    <svg class="info-icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="16" x2="12" y2="12"></line>
                        <line x1="12" y1="8" x2="12.01" y2="8"></line>
                    </svg>
                </span>
            </span>
        </div>
        <div class="card-body">
            <div class="asset-spec-grid">
                <div class="spec-item">
                    <span class="spec-label">Company Name</span>
                    <span class="spec-value" id="specName">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Trading Symbol</span>
                    <span class="spec-value" id="specSymbol">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Instrument Token</span>
                    <span class="spec-value monospace" id="specInstrumentToken">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Exchange Token</span>
                    <span class="spec-value monospace" id="specExchangeToken">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Exchange</span>
                    <span class="spec-value" id="specExchange">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Segment</span>
                    <span class="spec-value" id="specSegment">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Instrument Type</span>
                    <span class="spec-value" id="specInstrumentType">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Last Price</span>
                    <span class="spec-value monospace" id="specLastPrice">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Lot Size</span>
                    <span class="spec-value monospace" id="specLotSize">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Tick Size</span>
                    <span class="spec-value monospace" id="specTickSize">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Expiry Date</span>
                    <span class="spec-value monospace" id="specExpiry">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Strike Price</span>
                    <span class="spec-value monospace" id="specStrike">-</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label">Status</span>
                    <span class="spec-status-badge" id="specStatus">-</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart Row -->
    <div class="chart-panel card">
        <div class="chart-panel-header">
            <div class="panel-title-wrapper">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                </svg>
                <span class="panel-title" id="chartTitle">
                    Technical Candlestick Chart
                    <span class="info-tooltip-trigger" data-tooltip="Interactive price chart. Green bars show price went up; red bars show price went down. Overlay lines show average price trends.">
                        <svg class="info-icon" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </span>
            </div>
            <div class="chart-indicators">
                <span class="indicator-tag ema20" data-tooltip="Exponential Moving Average (20 periods). A line showing the average price over the last 20 bars, focusing on recent price action.">EMA (20)</span>
                <span class="indicator-tag ema50" data-tooltip="Exponential Moving Average (50 periods). A line showing the average price over the last 50 bars. Useful for identifying the broader trend.">EMA (50)</span>
                <span class="indicator-tag vwap" data-tooltip="Volume Weighted Average Price. A key line used by institutional traders showing the average price adjusted for trading volume.">VWAP</span>
            </div>
        </div>
        
        <div class="chart-panel-body">
            <!-- Candlestick chart pane -->
            <div id="priceChartContainer" class="chart-container-pane"></div>
            <!-- RSI pane -->
            <div id="rsiChartContainer" class="chart-container-pane indicator-pane">
                <div class="pane-label">
                    Relative Strength Index (RSI)
                    <span class="info-tooltip-trigger" data-tooltip="Relative Strength Index chart. The yellow line shows the momentum. It helps identify if a stock is over-purchased (above 70) or over-sold (below 30).">
                        <svg class="info-icon" viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </div>
            </div>
            <!-- MACD pane -->
            <div id="macdChartContainer" class="chart-container-pane indicator-pane">
                <div class="pane-label">
                    MACD (12, 26, 9)
                    <span class="info-tooltip-trigger" data-tooltip="MACD momentum chart. When the blue line crosses above the orange line, it's a buy signal. The height of the bars shows how strong the trend is.">
                        <svg class="info-icon" viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_StrategyFormulasModal" />

@section Scripts {
    <!-- TradingView Lightweight Charts CDN -->
    <script src="~/js/theme/lightweight-charts.standalone.production.js"></script>
    <!-- Microsoft SignalR JS Client CDN -->
    <script src="~/js/theme/signalr.min.js"></script>
    <script>
        window.QuantEdgeConfig = {
            apiBaseUrl: "@ViewBag.ApiBaseUrl"
        };
    </script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            // Open Modal
            $("#btnOpenReference").click(function() {
                $("#strategyFormulasModal").addClass("active");
                $("body").css("overflow", "hidden");
            });

            // Close Modal
            $("#btnCloseModal, #strategyFormulasModal").click(function(e) {
                if (e.target === this || $(e.target).closest('#btnCloseModal').length) {
                    $("#strategyFormulasModal").removeClass("active");
                    $("body").css("overflow", "");
                }
            });

            $(document).keydown(function(e) {
                if (e.key === "Escape" && $("#strategyFormulasModal").hasClass("active")) {
                    $("#strategyFormulasModal").removeClass("active");
                    $("body").css("overflow", "");
                }
            });

            // Tab switching
            $(".qe-modal-nav-btn").click(function() {
                const tabId = $(this).data("tab");
                $(".qe-modal-nav-btn").removeClass("active");
                $(".qe-modal-pane").removeClass("active");
                $(this).addClass("active");
                $(`#${tabId}`).addClass("active");
            });
        });
    </script>
}
